# --- 1. System & Cache (Always Ignore) ---
__pycache__/
**/*.py[cod]
*$py.class
.git/
.gitignore
.vscode/
.idea/
.env
.pytest_cache/
*.log

# --- 2. Build & OS Trash ---
build/
dist/
*.egg-info/
.DS_Store
Thumbs.db

# --- 3. Virtual Environments ---
venv/
env/
.venv/

# --- 4. DATA & MODELS ---
# Blacklist only the heavy/unnecessary folders
artifacts/model_cache/
artifacts/dataset/
artifacts/logs/
artifacts/reports/
*.zip
*.tar.gz

# --- 5. ALLOW THE TRAINED MODELS ---
# We keep the trained models and the directory structure
!artifacts/trained_models/
!artifacts/trained_models/*.joblib

